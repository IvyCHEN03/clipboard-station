{
  "manifest_version": 3,
  "name": "Linggan Image Collector",
  "version": "0.1.0",
  "description": "Collect image-heavy web pages into a selectable stack and save chosen images locally.",
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Linggan Image Collector"
  }
}
